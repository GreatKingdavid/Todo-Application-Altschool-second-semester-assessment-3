<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Reminders</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="container">
        <header style="display: flex; justify-content: space-between; align-items: baseline;">
            <h1 style="color: #007AFF;">My Tasks</h1>
            <span style="color: #888;"><%= todos.filter(t => t.status === 'pending').length %> Left</span>
        </header>

        <form action="/add" method="POST" class="add-reminder">
            <span style="color: #007AFF; font-size: 1.5rem;">+</span>
            <input type="text" name="title" placeholder="New Reminder" required autocomplete="off">
            <button type="submit" style="background:none; border:none; color:#007AFF; font-weight:bold; cursor:pointer;">Add</button>
        </form>

        <div class="reminder-list">
            <% if (todos.length === 0) { %>
                <div style="text-align: center; margin-top: 2rem; color: #444;">No tasks found</div>
            <% } %>
            
            <% todos.forEach(todo => { %>
                <div class="reminder-item">
                    <form action="/update/<%= todo._id %>" method="POST">
                        <input type="hidden" name="status" value="<%= todo.status === 'completed' ? 'pending' : 'completed' %>">
                        <button type="submit" class="circle-btn <%= todo.status === 'completed' ? 'checked' : '' %>"></button>
                    </form>

                    <div class="reminder-content" style="flex: 1; margin-left: 15px;">
                        <span class="title status-<%= todo.status %>">
                            <%= todo.title %>
                        </span>
                        <span class="time-display" data-timestamp="<%= todo.updatedAt %>" style="font-size: 0.9rem; color: #888; display: block; margin-top: 4px;">
                            Loading time...
                        </span>
                    </div>

                    <div style="display: flex; gap: 20px; align-items: center;">
                        <button onclick="editTask('<%= todo._id %>', '<%= todo.title %>')" class="edit-btn" style="font-size: 1.5rem; background:none; border:none; cursor:pointer;">✎</button>
                        
                        <form action="/update/<%= todo._id %>" method="POST" style="margin:0;">
                            <input type="hidden" name="status" value="deleted">
                            <button type="submit" class="trash-btn" style="font-size: 1.5rem; background:none; border:none; cursor:pointer;">🗑</button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <nav class="bottom-nav">
        <a href="/" class="active"><strong>All</strong><br>Task</a>
        <a href="/?status=pending">⌛<br>Pending</a>
        <a href="/?status=completed">✅<br>Completed</a>
        <a href="/logout">👤<br>Logout</a>
    </nav>

    <script>
        // Fix for the Timezone issue
        function formatLocalTime() {
            const timeElements = document.querySelectorAll('.time-display');
            timeElements.forEach(el => {
                const rawDate = el.getAttribute('data-timestamp');
                if (rawDate) {
                    const date = new Date(rawDate);
                    el.innerText = "Added " + date.toLocaleTimeString([], { 
                        hour: '2-digit', 
                        minute: '2-digit' 
                    });
                }
            });
        }

        function editTask(id, oldTitle) {
            const newTitle = prompt("Edit Task:", oldTitle);
            if (newTitle && newTitle.trim() !== "" && newTitle !== oldTitle) {
                fetch(`/update/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title: newTitle.trim() })
                }).then(() => window.location.reload());
            }
        }

        // Initialize time formatting
        formatLocalTime();
    </script>
</body>
</html>
