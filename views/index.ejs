<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Tasks</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/socket.io/socket.io.js"></script>
</head>
<body>
    <div class="container">
        <header>
            <h1>My Tasks</h1>
            <span><%= todos.filter(t => t.status === 'pending').length %> Left</span>
        </header>

        <!-- Add Task Form -->
        <form action="/add" method="POST" class="add-reminder">
            <span style="color: #007AFF; font-size: 1.5rem;">+</span>
            <input type="text" name="title" placeholder="New Reminder" required>
            <input type="datetime-local" name="dueDate">
            <button type="submit">Add</button>
        </form>

        <!-- Task List -->
        <div class="reminder-list">
            <% todos.forEach(todo => { %>
                <div class="reminder-item <%= todo.status === 'overdue' ? 'overdue' : '' %>">
                    <form action="/update/<%= todo._id %>" method="POST">
                        <button type="submit" class="circle-btn <%= todo.status === 'completed' ? 'checked' : '' %>"></button>
                        <input type="hidden" name="status" value="<%= todo.status === 'completed' ? 'pending' : 'completed' %>">
                    </form>

                    <div class="reminder-content">
                        <span class="title status-<%= todo.status %>">
                            <%= todo.title %>
                        </span>
                        <% if (todo.dueDate) { %>
                            <span class="due-date <%= todo.status === 'overdue' ? 'overdue' : '' %>">
                                Due: <%= new Date(todo.dueDate).toLocaleString() %>
                            </span>
                        <% } %>
                        <span class="time-display">Loading...</span>
                    </div>

                    <div class="actions">
                        <% if (todo.status !== 'completed') { %>
                            <button onclick="editTask('<%= todo._id %>', '<%= todo.title %>')">✎</button>
                        <% } %>
                        <form action="/update/<%= todo._id %>" method="POST">
                            <input type="hidden" name="status" value="deleted">
                            <button type="submit">🗑</button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <!-- Bottom Navigation -->
    <nav class="bottom-nav">
        <a href="/">All</a>
        <a href="/?status=pending">Pending</a>
        <a href="/?status=completed">Completed</a>
        <a href="/logout">Logout</a>
    </nav>

    <script>
        const socket = io({ auth: { token: document.cookie.split('; ').find(r => r.startsWith('jwt='))?.split('=')[1] } });

        socket.on('taskOverdue', data => {
            alert(`⚠️ OVERDUE: ${data.title}`);
            location.reload();
        });

        // Time formatting (existing logic)
        // ... (you can keep your original formatLocalTime function here)
    </script>
</body>
</html>
