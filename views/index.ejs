<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>Reminders</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

    <div class="container">
        <header style="display: flex; justify-content: space-between; align-items: baseline;">
            <h1 style="color: #007AFF;">My Tasks</h1>
            <span style="color: #888;"><%= todos.filter(t => t.status === 'pending').length %> Left</span>
        </header>

        <form action="/add" method="POST" class="add-reminder">
            <span style="color: #007AFF; font-size: 1.5rem;">+</span>
            <input type="text" name="title" placeholder="New Reminder" required autocomplete="off">
            <button type="submit" style="background:none; border:none; color:#007AFF; font-weight:bold; cursor:pointer;">Add</button>
        </form>

        <div class="reminder-list">
            <% todos.forEach(todo => { %>
                <div class="reminder-item">
                    <form action="/update/<%= todo._id %>" method="POST">
                        <input type="hidden" name="status" value="<%= todo.status === 'completed' ? 'pending' : 'completed' %>">
                        <button type="submit" class="circle-btn <%= todo.status === 'completed' ? 'checked' : '' %>"></button>
                    </form>

                    <div class="reminder-content" style="flex: 1; margin-left: 15px;">
                        <span class="title status-<%= todo.status %>">
                            <%= todo.title %>
                        </span>
                        <span class="time-display" 
                              data-created="<%= todo.createdAt.toISOString() %>" 
                              data-updated="<%= todo.updatedAt.toISOString() %>" 
                              data-status="<%= todo.status %>"
                              style="font-size: 0.9rem; color: #888; display: block; margin-top: 4px;">
                            Loading time...
                        </span>
                    </div>

                    <div style="display: flex; gap: 20px; align-items: center;">
                        <% if (todo.status !== 'completed') { %>
                            <button onclick="editTask('<%= todo._id %>', '<%= todo.title %>')" class="edit-btn" style="font-size: 1.9rem; background:none; border:none; cursor:pointer;">✎</button>
                        <% } %>
                        
                        <form action="/update/<%= todo._id %>" method="POST" style="margin:0;">
                            <input type="hidden" name="status" value="deleted">
                            <button type="submit" class="trash-btn" style="font-size: 1.5rem; background:none; border:none; cursor:pointer;">🗑</button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <nav class="bottom-nav">
        <a href="/" id="nav-all"><strong>All</strong><br>Task</a>
        <a href="/?status=pending" id="nav-pending">⌛<br>Pending</a>
        <a href="/?status=completed" id="nav-completed">✅<br>Completed</a>
        <a href="/logout">👤<br>Logout</a>
    </nav>

    <script>
        function formatLocalTime() {
            const timeElements = document.querySelectorAll('.time-display');
            timeElements.forEach(el => {
                const created = new Date(el.getAttribute('data-created'));
                const updated = new Date(el.getAttribute('data-updated'));
                const status = el.getAttribute('data-status');
                
                if (updated) {
                    const formattedTime = updated.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                    
                    if (status === 'completed') {
                        el.innerText = "Completed at " + formattedTime;
                    } else if (updated.getTime() > created.getTime() + 2000) { 
                        // If updated is > 2 seconds after created, it counts as an edit
                        el.innerText = "Edited at " + formattedTime;
                    } else {
                        el.innerText = "Added at " + formattedTime;
                    }
                }
            });
        }

        function highlightNav() {
            const params = new URLSearchParams(window.location.search);
            const status = params.get('status');
            
            // Clear existing actives
            document.querySelectorAll('.bottom-nav a').forEach(link => link.classList.remove('active'));

            if (status === 'pending') {
                document.getElementById('nav-pending').classList.add('active');
            } else if (status === 'completed') {
                document.getElementById('nav-completed').classList.add('active');
            } else if (window.location.pathname === '/') {
                document.getElementById('nav-all').classList.add('active');
            }
        }

        function editTask(id, oldTitle) {
            const newTitle = prompt("Edit Task:", oldTitle);
            if (newTitle && newTitle.trim() !== "" && newTitle !== oldTitle) {
                fetch(`/update/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title: newTitle.trim() })
                }).then(() => window.location.reload());
            }
        }

        // Initialize
        formatLocalTime();
        highlightNav();
    </script>
</body>
</html>
