<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Tasks</title>
    <link rel="stylesheet" href="/style.css">
    <script src="/socket.io/socket.io.js"></script>
</head>
<body>
    <div class="container">
        <header>
            <h1>My Tasks</h1>
            <span><%= todos.filter(t => t.status === 'pending').length %> Left</span>
        </header>

        <!-- Add Task Form -->
        <form action="/add" method="POST" class="add-reminder">
            <span style="color: #007AFF; font-size: 1.5rem;">+</span>
            <input type="text" name="title" placeholder="New Reminder" required>
            <input type="datetime-local" name="dueDate">
            <button type="submit">Add</button>
        </form>

        <!-- Task List -->
        <div class="reminder-list">
            <% todos.forEach(todo => { %>
                <div class="reminder-item <%= todo.status === 'overdue' ? 'overdue' : '' %>" data-status="<%= todo.status %>" data-due="<%= todo.dueDate ? new Date(todo.dueDate).toISOString() : '' %>">
                    <form action="/update/<%= todo._id %>" method="POST">
                        <button type="submit" class="circle-btn <%= todo.status === 'completed' ? 'checked' : '' %>"></button>
                        <input type="hidden" name="status" value="<%= todo.status === 'completed' ? 'pending' : 'completed' %>">
                    </form>

                    <div class="reminder-content">
                        <span class="title status-<%= todo.status %>">
                            <%= todo.title %>
                        </span>
                        <% if (todo.dueDate) { %>
                            <span class="due-date <%= todo.status === 'overdue' ? 'overdue' : '' %>">
                                Due: <%= new Date(todo.dueDate).toLocaleString() %>
                            </span>
                        <% } %>
                        <span class="time-display">Loading...</span>
                    </div>

                    <div class="actions">
                        <% if (todo.status !== 'completed') { %>
                            <button onclick="editTask('<%= todo._id %>', '<%= todo.title %>')">✎</button>
                        <% } %>
                        <form action="/update/<%= todo._id %>" method="POST">
                            <input type="hidden" name="status" value="deleted">
                            <button type="submit">🗑</button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>

    <!-- Bottom Navigation -->
    <nav class="bottom-nav">
        <a href="/">All</a>
        <a href="/?status=pending">Pending</a>
        <a href="/?status=completed">Completed</a>
        <a href="/logout">Logout</a>
    </nav>

    <script>
        const socket = io({ auth: { token: "<%= token %>" } });

        socket.on('connect_error', err => {
            console.error('Socket connection failed:', err.message);
        });

        socket.on('taskOverdue', data => {
            alert(`⚠️ OVERDUE: ${data.title}`);
            location.reload();
        });

        socket.on('taskCompleted', data => {
            alert(`✅ Completed: ${data.title}`);
            location.reload();
        });

        // Fires only on genuine reconnects (not the initial connect), so a
        // user who was briefly disconnected sees fresh task state once back
        socket.io.on('reconnect', () => {
            location.reload();
        });

        // Time formatting: shows a live "Due in Xh Ym" / "Overdue by Xh Ym"
        // countdown next to each task, without needing a page reload.
        function formatDuration(ms) {
            const abs = Math.abs(ms);
            const minutes = Math.floor(abs / 60000);
            const hours = Math.floor(minutes / 60);
            const days = Math.floor(hours / 24);

            if (days > 0) return `${days}d ${hours % 24}h`;
            if (hours > 0) return `${hours}h ${minutes % 60}m`;
            if (minutes > 0) return `${minutes}m`;
            return 'less than a minute';
        }

        function updateTimeDisplays() {
            document.querySelectorAll('.reminder-item').forEach(item => {
                const display = item.querySelector('.time-display');
                if (!display) return;

                const status = item.dataset.status;
                const dueAttr = item.dataset.due;

                if (status === 'completed') {
                    display.textContent = 'Completed';
                    return;
                }

                if (!dueAttr) {
                    display.textContent = '';
                    return;
                }

                const diff = new Date(dueAttr) - new Date();
                display.textContent = diff > 0
                    ? `Due in ${formatDuration(diff)}`
                    : `Overdue by ${formatDuration(diff)}`;
            });
        }

        updateTimeDisplays();
        setInterval(updateTimeDisplays, 30000); // refresh every 30s
    </script>
</body>
</html>