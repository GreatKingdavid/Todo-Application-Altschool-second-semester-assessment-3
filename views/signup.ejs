<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up | Todo App</title>
    <link rel="stylesheet" href="/style.css?v=1.2">
</head>
<body class="auth-page">
    <div class="container">
        <form id="signup-form">
            <h2>Create Account</h2>
            
            <label for="email">Email</label>
            <input type="text" name="email" id="email" required placeholder="name@email.com" />
            <div class="email error"></div>

            <label for="password">Password</label>
            <input type="password" name="password" id="password" required placeholder="Min. 6 characters" />
            <div class="password error"></div>

            <button type="submit">Sign Up</button>
            <p>Already have an account? <a href="/login">Log in</a></p>
        </form>
    </div>

    <script>
        const form = document.querySelector('#signup-form');
        const emailError = document.querySelector('.email.error');
        const passwordError = document.querySelector('.password.error');

        form.addEventListener('submit', async (e) => {
            e.preventDefault(); // This stops the page from refreshing

            // Reset errors
            emailError.textContent = '';
            passwordError.textContent = '';

            // Get values from the input fields
            const email = form.email.value;
            const password = form.password.value;

            console.log("Attempting to sign up with:", email);

            try {
                const res = await fetch('/signup', { 
                    method: 'POST', 
                    body: JSON.stringify({ email, password }),
                    headers: {'Content-Type': 'application/json'}
                });

                const data = await res.json();
                console.log("Server response:", data);

                if (data.error) {
                    // Show error message if registration failed
                    emailError.textContent = data.error;
                }
                
                if (data.user) {
                    // Success! Redirect to home page
                    alert("Signup Successful! Redirecting...");
                    location.assign('/');
                }
            } catch (err) {
                console.error("Fetch Error:", err);
                alert("Connection failed. Check your terminal for errors.");
            }
        });
    </script>
</body>
</html>